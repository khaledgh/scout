# --- App ---
APP_NAME=Kashfi
APP_ENV=development
APP_PORT=8080
APP_URL=http://localhost:8080
APP_TIMEZONE=Asia/Beirut

# --- Database (MySQL) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=scout
DB_USER=root
DB_PASSWORD=
DB_PARAMS=charset=utf8mb4&parseTime=True&loc=Local
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=300

# --- Auth / JWT ---
JWT_SECRET=change_me_use_a_long_random_string_here
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
BCRYPT_COST=12

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Uploads ---
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=15
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,video/mp4
PUBLIC_UPLOAD_PATH=/uploads

# --- Attendance / Geofence ---
GEOFENCE_RADIUS_METERS=150
QR_SIGNING_SECRET=change_me_qr_secret

# --- Gamification ---
XP_PER_ATTENDANCE=10
XP_PER_QUIZ_PASS=20
XP_PER_LEADERSHIP=50
LEVEL_BASE_XP=100

# --- Notifications (Web Push - VAPID) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# --- Email (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com

# --- Jobs ---
REMINDER_LOOKAHEAD_HOURS=24
MONTHLY_REPORT_DAY=1
